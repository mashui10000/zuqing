.head-progress { margin: -8rpx 0 28rpx; }
.meter-card { padding: 28rpx; margin-bottom: 18rpx; }
.meter-card.active { border-color: rgba(8,119,255,.45); box-shadow: 0 18rpx 54rpx rgba(8,119,255,.14); }
.meter-head { margin-bottom: 24rpx; }
.room-title { margin-bottom: 5rpx; font-weight: 680; }
.meter-reading-group + .meter-reading-group { margin-top: 22rpx; }
.meter-kind { margin-bottom: 12rpx; font-weight: 680; }
.reading-pair { display: grid; grid-template-columns: 1fr; gap: 14rpx; }
.reading-pair > view { min-width: 0; }
.reading-readonly { justify-content: space-between; background: var(--surface-muted); color: var(--fg); }
.auto-mark { flex: 0 0 auto; padding: 6rpx 10rpx; border-radius: 999rpx; background: #E9F7EE; color: var(--success); font-size: 22rpx; font-weight: 650; }
.other-row { min-height: 82rpx; margin-top: 16rpx; border-top: 1rpx solid var(--border); }
.small-input { width: 180rpx; height: 88rpx; padding: 0 18rpx; text-align: right; border-radius: 22rpx; background: var(--surface-muted); }
.save-btn { width: 100%; }

@media (max-width: 340px) {
  .reading-pair { grid-template-columns: 1fr; }
}
