.scope-tabs { min-height: 72rpx; margin-bottom: 14rpx; display: flex; align-items: center; justify-content: flex-start; gap: 12rpx; }
.scope-tab { width: auto; min-width: 0; min-height: 72rpx; margin: 0; padding: 7rpx 0; flex: 0 0 auto; display: flex; align-items: center; color: var(--muted); font-size: 22rpx; font-weight: 650; line-height: 1; }
.scope-tab-visual { min-width: 132rpx; min-height: 58rpx; padding: 0 24rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid transparent; border-radius: 29rpx; background: var(--surface-muted); white-space: nowrap; }
.scope-tab.active .scope-tab-visual { border-color: var(--border); background: var(--surface); color: var(--primary); box-shadow: 0 3rpx 12rpx rgba(17,24,39,.08); }
.filter-scroll { width: 100%; margin-bottom: 18rpx; white-space: nowrap; }
.filter-row { display: inline-flex; gap: 8rpx; padding-right: 28rpx; }
.bill-group { margin-bottom: 24rpx; }
.bill-group-head { min-height: 46rpx; padding: 0 6rpx 10rpx; display: flex; align-items: flex-end; justify-content: space-between; gap: 18rpx; }
.bill-group-title { color: var(--fg); font-size: 25rpx; font-weight: 720; }
.bill-group-summary { color: var(--muted); font-size: 20rpx; }
.bill-group-card { overflow: hidden; }
.bill-main { min-width: 0; flex: 1; }
.bill-title { max-width: 310rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 680; }
.bill-side { flex: 0 0 auto; display: flex; align-items: center; gap: 10rpx; }
.amount { font-size: 27rpx; font-weight: 650; }
.bill-row .muted { display: block; margin-top: 7rpx; font-size: 22rpx; }
.collection-date { display: block; margin-top: 6rpx; color: var(--primary); font-size: 21rpx; font-weight: 680; }
