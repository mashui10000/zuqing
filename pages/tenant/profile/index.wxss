.tenant-profile-page { padding-bottom: calc(44rpx + env(safe-area-inset-bottom)); }
.profile-head { margin-top: 8rpx; }
.invite-source { min-height: 118rpx; padding: 22rpx 24rpx; display: flex; align-items: center; gap: 18rpx; box-shadow: none; }
.source-mark { width: 66rpx; height: 66rpx; flex: 0 0 auto; display: grid; place-items: center; border-radius: 20rpx; background: var(--surface-muted); color: var(--muted); font-weight: 680; }
.invite-source .muted { display: block; margin-top: 5rpx; font-size: 22rpx; }
.count-card { min-height: 118rpx; margin-top: 22rpx; padding: 22rpx 24rpx; display: flex; align-items: center; justify-content: space-between; gap: 18rpx; box-shadow: none; }
.count-title { font-weight: 700; }
.count-card .muted { display: block; margin-top: 5rpx; font-size: 21rpx; }
.count-picker { min-width: 142rpx; height: 88rpx; padding: 0 22rpx; display: flex; align-items: center; justify-content: space-between; gap: 14rpx; border-radius: 22rpx; background: var(--primary-soft); color: var(--primary); font-weight: 680; }
.occupant-card { margin-top: 22rpx; padding: 26rpx; box-shadow: none; }
.occupant-card-error { border-color: rgba(215, 0, 21, .34); background: #FFFDFD; }
.occupant-heading { margin-bottom: 24rpx; }
.occupant-title { font-size: 29rpx; font-weight: 740; }
.occupant-rule, .optional { color: var(--muted); font-size: 20rpx; }
.form-item + .form-item { margin-top: 22rpx; }
.field-input-error { border-color: var(--danger) !important; background: #FFF7F7 !important; }
.field-hint-error { display: block; margin-top: 9rpx; color: var(--danger); font-size: 21rpx; line-height: 1.4; }
.picker-arrow { color: var(--muted); font-size: 34rpx; }
.form-error { margin-top: 18rpx; padding: 18rpx 22rpx; border-radius: 18rpx; background: #FFECEE; color: var(--danger); font-size: 23rpx; line-height: 1.4; }
.privacy-card { margin: 22rpx 4rpx 0; color: var(--muted); font-size: 21rpx; line-height: 1.55; }
.privacy-card view { margin-bottom: 6rpx; color: var(--fg); font-weight: 680; }
.submit-button { margin-top: 28rpx; }
.full { width: 100%; }
